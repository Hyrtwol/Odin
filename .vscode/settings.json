{
	"editor.wordWrapColumn": 120,
	"editor.rulers": [
		120
	],
	"cSpell.language": "en-GB",
	"cSpell.words": [
		"coreclr",
		"dylib",
		"elif",
		"ifdef",
		"ilasm",
		"ildasm",
		"isize",
		"levenstein",
		"libcoreclr",
		"metaprogramming",
		"microarch",
		"microarchitecture",
		"netcore",
		"nupkg",
		"runtimes",
		"struct",
		"subtarget"
	],
	"markdownlint.config": {
		"no-hard-tabs": false,
		"line-length": false
	},
	"[markdown]": {
		"editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
	},
	"omnisharp.autoStart": false,
	"typescript.tsc.autoDetect": "off",
	"npm.autoDetect": "off",
	"files.exclude": {
		"**/.git": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true,
		"**/desktop.ini": true
	},
	"files.associations": {
		"*.rc": "cpp",
		"*.rh": "cpp"
	}
}